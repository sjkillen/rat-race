[sub_resource type="GDScript" id="GDScript_r7jd2"]
script/source = "extends Node3D

const num_drivers = 100
const RAY_LENGTH := 1000
var mouse_on_track: bool = false
var mouse_position: Vector3
var current_waypoint = 0

signal click_track(pos: Vector3)

func _ready() -> void:
	#visualize_waypoints()
	distribute_drivers()

func distribute_drivers():
	var inc: int = floor(%track.waypoints.size() / num_drivers)
	for i in range(0, %track.waypoints.size(), inc):
		create_driver(%track.waypoints[i])
		
func create_driver(waypoint: WaypointData):
	var driver: NPCDriver = preload(\"res://tests/test_npc_driver.tscn\").instantiate()
	driver.waypoint_reached.connect(driver_reached_waypoint)
	add_child(driver)
	driver.global_position = waypoint.position
	driver.set_waypoint(waypoint)

func driver_reached_waypoint(who: NPCDriver, waypoint: WaypointData):
	var next_waypoint = (waypoint.index + 1) % %track.waypoints.size()
	who.set_waypoint(%track.waypoints[next_waypoint])

func visualize_waypoints():
	for waypoint in %track.waypoints:
		var inst: Node3D = preload(\"test_waypoint_marker.tscn\").instantiate()
		add_child(inst)
		inst.global_position = waypoint

# https://docs.godotengine.org/en/stable/tutorials/physics/ray-casting.html
func cast_ray_from_mouse() -> void:
	var space_state := get_world_3d().direct_space_state
	var cam := get_viewport().get_camera_3d()
	var mousepos := get_viewport().get_mouse_position()

	var origin := cam.project_ray_origin(mousepos)
	var end := origin + cam.project_ray_normal(mousepos) * RAY_LENGTH
	var query := PhysicsRayQueryParameters3D.create(origin, end)
	query.collide_with_areas = true

	var result = space_state.intersect_ray(query)
	if result.has(\"position\"):
		mouse_on_track = true
		mouse_position = result.get(\"position\")
	else:
		mouse_on_track = false
		mouse_position = Vector3.ZERO
		
func _physics_process(_delta: float):
	cast_ray_from_mouse()

func _input(event: InputEvent) -> void:
	if not mouse_on_track:
		return
	if event is InputEventMouse and event.is_pressed() and event.button_mask == MOUSE_BUTTON_LEFT:
		click_track.emit(mouse_position)
"

